rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /logs/{logId} {
      allow read, write: if true;
    }
    match /forumComments/{commentId} {
      allow read, write: if true;
    }
    match /feedbackMessages/{messageId} {
      allow read, write: if true;
    }
    match /passwords/{docId} {
      allow read, write: if true;
    }
  }
}
